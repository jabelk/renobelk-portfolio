---
// SiteHeader — site name + primary nav (Work, About).
interface NavItem {
  href: string;
  label: string;
  external?: boolean;
}

const navItems: NavItem[] = [
  { href: "/work/", label: "Work" },
  { href: "/about/", label: "About" },
  { href: "https://github.com/jabelk", label: "GitHub", external: true },
  { href: "https://www.linkedin.com/in/renobelk", label: "LinkedIn", external: true },
];

const path = Astro.url.pathname;
---

<header class="site-header">
  <div class="site-header-inner">
    <a href="/" class="site-title">Jason Belk</a>
    <nav class="site-nav" aria-label="Primary">
      <ul class="site-nav-list">
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={!item.external && path === item.href ? "page" : undefined}
                target={item.external ? "_blank" : undefined}
                rel={item.external ? "noopener" : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>
